{
	"name": "auth",
	"version": "0.1.1",
	"private": true,
	"scripts": {
		"dev:frontend": "next dev --turbopack",
		"dev:backend": "npx convex dev",
		"dev:email": "email dev",
		"dev": "concurrently --kill-others --prefix-colors blue,yellow --names 'next,convex' 'pnpm dev:frontend' 'pnpm dev:backend'",
		"build": "next build",
		"start": "next start",
		"lint": "eslint .",
		"format": "prettier --write .",
		"pull:convex": "rm -rf ./convex && cp -r ../convex ./convex",
		"changeset": "changeset",
		"version-packages": "changeset version",
		"ci:release": "jsrepo publish && changeset tag"
	},
	"dependencies": {
		"@ark-ui/react": "^5.36.2",
		"@better-auth/api-key": "1.6.9",
		"@convex-dev/better-auth": "0.12.0",
		"@convex-dev/migrations": "^0.3.4",
		"@convex-dev/resend": "0.2.3",
		"@icons-pack/react-simple-icons": "13.7.0",
		"@zxcvbn-ts/core": "^3.0.4",
		"@zxcvbn-ts/language-common": "^3.0.4",
		"@zxcvbn-ts/language-en": "^3.0.2",
		"better-auth": "1.6.9",
		"clsx": "^2.1.1",
		"convex": "1.36.1",
		"convex-helpers": "^0.1.115",
		"lucide-react": "^0.577.0",
		"next": "16.2.4",
		"path-to-regexp": "^8.4.2",
		"react": "^19.2.5",
		"react-dom": "^19.2.5",
		"react-easy-crop": "^5.5.7",
		"sonner": "^2.0.7",
		"tailwind-merge": "^3.5.0"
	},
	"devDependencies": {
		"@changesets/cli": "^2.31.0",
		"@skeletonlabs/skeleton": "^4.15.2",
		"@tailwindcss/forms": "^0.5.11",
		"@tailwindcss/postcss": "^4.2.4",
		"@types/node": "^24.12.2",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"concurrently": "^9.2.1",
		"eslint": "^9.39.4",
		"eslint-config-next": "16.2.4",
		"jsrepo": "^3.7.0",
		"prettier": "^3.8.3",
		"prettier-plugin-tailwindcss": "^0.7.3",
		"tailwindcss": "^4.2.4",
		"tw-animate-css": "^1.4.0",
		"typescript": "^6.0.3"
	},
	"packageManager": "pnpm@10.33.2"
